    "yaml-language-server": "^1.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@types/pg": "^8.20.0",
    "typescript": "^5.8.3"
  }
}
