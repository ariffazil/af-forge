# AF FORGE — Caddy Reverse Proxy
# Public entrypoint: only Caddy faces the internet. All backend services are internal.

:80 {
	bind 0.0.0.0

	# Health check for gateway itself
	respond /healthz "OK" 200

	# arifOS MCP governance kernel
	handle /mcp {
		reverse_proxy arifos-mcp:8080
	}
	handle /arifos/* {
		reverse_proxy arifos-mcp:8080
	}

	# AF FORGE bridge server — operator, sense, metrics, human escalation
	handle /operator/* {
		reverse_proxy af-forge-bridge:7071
	}
	handle /metrics {
		reverse_proxy af-forge-bridge:7071
	}
	handle /sense {
		reverse_proxy af-forge-bridge:7071
	}
	handle /human-expert/* {
		reverse_proxy af-forge-bridge:7071
	}
	handle /health {
		reverse_proxy af-forge-bridge:7071
	}
	handle /ready {
		reverse_proxy af-forge-bridge:7071
	}

	# Default respond
	handle {
		respond "AF FORGE Gateway" 200
	}
}
