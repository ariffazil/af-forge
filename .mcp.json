{
  "mcpServers": {
    "arifos-local": {
      "command": "bash",
      "args": [
        "/root/.github/mcp/start-arifos-stdio.sh"
      ],
      "cwd": "/root",
      "type": "local"
    },
    "geox-local": {
      "command": "bash",
      "args": [
        "/root/.github/mcp/start-geox-stdio.sh"
      ],
      "cwd": "/root",
      "type": "local"
    },
    "playwright": {
      "command": "bash",
      "args": [
        "/root/.github/mcp/start-playwright.sh"
      ],
      "cwd": "/root",
      "type": "local"
    },
    "af-forge": {
      "command": "bash",
      "args": [
        "/root/af-forge/.github/mcp/start-af-forge-stdio.sh"
      ],
      "cwd": "/root/af-forge",
      "type": "local"
    }
  }
}
