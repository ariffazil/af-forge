# AF Forge Runtime Environment

# LLM Provider
AGENT_WORKBENCH_PROVIDER=mock
AGENT_WORKBENCH_MODEL=gpt-5
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://ollama:11434

# Trust / Safety
AGENT_WORKBENCH_TRUST_LOCAL_VPS=0
ENABLE_DANGEROUS_TOOLS=false
ENABLE_BACKGROUND_JOBS=false
ENABLE_EXPERIMENTAL_TOOLS=false

# Timeouts
AGENT_WORKBENCH_LLM_TIMEOUT_MS=120000
AGENT_WORKBENCH_COMMAND_TIMEOUT_MS=30000

# File / Command Policy
AGENT_WORKBENCH_MAX_FILE_BYTES=262144
AGENT_WORKBENCH_ALLOWED_COMMAND_PREFIXES=
AGENT_WORKBENCH_BLOCKED_COMMAND_PATTERNS=

# Paths (file-backed defaults; Postgres migration recommended for production)
AGENT_WORKBENCH_MEMORY_PATH=~/.agent-workbench/memory.json
AGENT_WORKBENCH_SCOREBOARD_PATH=~/.agent-workbench/scoreboard.json
AGENT_WORKBENCH_RUN_METRICS_DIR=~/.agent-workbench/metrics

# Mode
AGENT_WORKBENCH_DEFAULT_MODE=external

# Bridge / Escalation
AF_FORGE_PORT=7071
HUMAN_ESCALATION_WEBHOOK_URL=
ARIFOS_GOVERNANCE_URL=

# Pricing
AGENT_WORKBENCH_INPUT_COST_PER_MILLION_TOKENS=0
AGENT_WORKBENCH_OUTPUT_COST_PER_MILLION_TOKENS=0

# Data plane (Postgres / Redis)
POSTGRES_URL=postgresql://af_forge:af_forge_secret@postgres:5432/af_forge
POSTGRES_USER=af_forge
POSTGRES_PASSWORD=af_forge_secret
POSTGRES_DB=af_forge
REDIS_URL=redis://redis:6379

# Observability
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_in_production
